# Optimization Engine Patterns for EMHASS

## Critical Rules

- **Solver Abstraction**: NEVER directly instantiate solver objects - use factory pattern to support HiGHS, COIN-BC, GLPK, and future solvers
- **Constraint Builder Pattern**: Implement constraints as modular builders - each subsystem (thermal, EV, battery) adds its own constraints
- **Variable Naming Convention**: Use descriptive variable names with system prefixes: `P_hp_space_heating`, `SOC_battery`, `P_ev_charging_tesla`
- **Time Series Modeling**: ALL optimization variables MUST be time-indexed arrays - never single scalar values for multi-period optimization
- **Capacity Constraints**: Implement separate min/max capacity constraints for each device - don't embed in power calculations
- **Efficiency Modeling**: Model efficiency as constraints, not in objective function - maintain LP linearity
- **State Persistence**: Implement SoC continuity constraints for batteries, thermal storage, and EVs across time periods
- **Objective Function Separation**: Keep cost components (electricity, gas, capacity charges) as separate terms for transparency
- **Constraint Validation**: Validate all constraints for feasibility before solving - provide clear error messages for infeasible models
- **Performance Monitoring**: Track solver time, iteration count, and solution quality metrics for optimization tuning

## Examples

<example>
  ```python
  # GOOD: Modular constraint builder with clear variable management
  class OptimizationModel:
      def __init__(self, time_periods: int, solver_type: str = "HiGHS"):
          self.model = self._create_solver(solver_type)
          self.time_periods = time_periods
          self.variables = {}
          self.constraints = {}
          
      def add_subsystem(self, subsystem: OptimizationSubsystem) -> None:
          """Add subsystem variables and constraints"""
          subsystem_vars = subsystem.create_variables(self.model, self.time_periods)
          self.variables.update(subsystem_vars)
          
          subsystem_constraints = subsystem.create_constraints(self.model, subsystem_vars)
          self.constraints.update(subsystem_constraints)
      
      def add_thermal_system(self, thermal_config: dict) -> None:
          """Add thermal system optimization components"""
          thermal_subsystem = ThermalOptimizationSubsystem(thermal_config)
          self.add_subsystem(thermal_subsystem)
      
      def solve_optimization(self) -> OptimizationResults:
          """Solve LP model with error handling and performance tracking"""
          start_time = time.time()
          try:
              status = self.model.solve()
              solve_time = time.time() - start_time
              
              if status != pulp.LpStatusOptimal:
                  raise OptimizationError(f"Solver failed with status: {status}")
              
              return self._extract_results(solve_time)
          except Exception as e:
              self.logger.error(f"Optimization failed: {e}")
              raise
  
  class ThermalOptimizationSubsystem:
      def create_variables(self, model, time_periods: int) -> Dict[str, Any]:
          """Create thermal system decision variables"""
          variables = {}
          
          # Heat pump power variables with bounds
          variables['P_hp_space'] = [
              pulp.LpVariable(f"P_hp_space_{t}", 
                            lowBound=0, 
                            upBound=self.config['hp_max_power'])
              for t in range(time_periods)
          ]
          
          # Gas boiler power variables
          variables['P_gb_space'] = [
              pulp.LpVariable(f"P_gb_space_{t}",
                            lowBound=0,
                            upBound=self.config['gb_max_power'])
              for t in range(time_periods)
          ]
          
          # Thermal buffer state of charge
          variables['SOC_thermal_buffer'] = [
              pulp.LpVariable(f"SOC_thermal_buffer_{t}",
                            lowBound=self.config['thermal_buffer_min_soc'],
                            upBound=self.config['thermal_buffer_max_soc'])
              for t in range(time_periods)
          ]
          
          return variables
      
      def create_constraints(self, model, variables: Dict[str, Any]) -> Dict[str, Any]:
          """Create thermal system constraints"""
          constraints = {}
          
          # Thermal buffer energy balance constraints
          for t in range(1, len(variables['SOC_thermal_buffer'])):
              constraints[f'thermal_buffer_balance_{t}'] = (
                  variables['SOC_thermal_buffer'][t] == 
                  variables['SOC_thermal_buffer'][t-1] + 
                  (variables['P_hp_space'][t] * self.config['hp_efficiency'] * self.timestep_hours) -
                  (self.thermal_demand[t] * self.timestep_hours) -
                  (self.config['thermal_loss_rate'] * self.timestep_hours)
              )
              model += constraints[f'thermal_buffer_balance_{t}']
          
          # COP-based efficiency constraints (temperature dependent)
          for t in range(len(variables['P_hp_space'])):
              cop = self._calculate_cop(self.outdoor_temp[t])
              constraints[f'hp_thermal_output_{t}'] = (
                  variables['P_hp_space'][t] * cop >= self.thermal_demand[t]
              )
              model += constraints[f'hp_thermal_output_{t}']
          
          return constraints
  ```
