  # GOOD: Performance-optimized optimization engine with monitoring
  import time
  import psutil
  import numpy as np
  from functools import lru_cache
  from typing import Optional, Dict, Any
  
  class PerformanceOptimizedOptimizer:
      def __init__(self, config: dict, logger: logging.Logger):
          self.config = config
          self.logger = logger
          self.performance_metrics = PerformanceMetrics()
          
          # Resource limits from configuration
          self.max_solve_time = config.get('max_solve_time_seconds', 60)
          self.max_memory_mb = config.get('max_memory_mb', 1024)
          
          # Initialize only essential components
          self._solver_factory = SolverFactory()
          self._constraint_cache = {}
          
      def optimize(self, forecast_data: Dict[str, np.ndarray], 
                  subsystems: Optional[List[str]] = None) -> OptimizationResult:
          """Memory and performance optimized optimization"""
          
          # Start performance monitoring
          start_time = time.time()
          start_memory = psutil.Process().memory_info().rss / 1024 / 1024
          
          try:
              # Pre-validate resource availability
              if start_memory > self.max_memory_mb * 0.8:
                  self.logger.warning(f"High memory usage before optimization: {start_memory:.1f}MB")
                  self._cleanup_caches()
              
              # Determine optimization complexity based on available resources
              optimization_mode = self._determine_optimization_mode(
                  subsystems, start_memory, self.max_solve_time
              )
              
              # Build optimization model with complexity management
              model = self._build_optimized_model(forecast_data, optimization_mode)
              
              # Configure solver with performance constraints
              solver = self._configure_solver_for_performance(optimization_mode)
              
              # Execute optimization with monitoring
              result = self._solve_with_monitoring(model, solver)
              
              # Record performance metrics
              solve_time = time.time() - start_time
              peak_memory = psutil.Process().memory_info().rss / 1024 / 1024
              
              self.performance_metrics.record_optimization(
                  solve_time=solve_time,
                  peak_memory=peak_memory,
                  model_complexity=optimization_mode,
                  status=result.status
              )
              
              return result
              
          except Exception as e:
              solve_time = time.time() - start_time
              self.logger.error(f"Optimization failed after {solve_time:.2f}s: {e}")
              raise
      
      def _determine_optimization_mode(self, subsystems: List[str], 
                                     current_memory: float, 
                                     time_budget: int) -> str:
          """Determine optimization complexity based on resources"""
          
          # Calculate model complexity score
          complexity_score = 0
          if subsystems:
              if 'thermal_systems' in subsystems:
                  complexity_score += 3  # Thermal systems add significant complexity
              if 'ev_charging' in subsystems:
                  complexity_score += 2  # EV charging moderate complexity
              if 'capacity_tariffs' in subsystems:
                  complexity_score += 1  # Capacity tariffs minimal complexity
          
          # Determine mode based on resources and complexity
          if current_memory > self.max_memory_mb * 0.7 or time_budget < 30:
              return 'simplified'  # Reduce model complexity
          elif complexity_score > 5 and time_budget < 60:
              return 'balanced'   # Moderate complexity
          else:
              return 'full'       # Full complexity model
      
      @lru_cache(maxsize=32)
      def _get_cached_constraint_matrix(self, config_hash: str, 
                                       num_periods: int) -> np.ndarray:
          """Cache constraint matrices for repeated optimization scenarios"""
          # Expensive constraint matrix calculation
          return self._build_constraint_matrix(config_hash, num_periods)
      
      def _build_optimized_model(self, forecast_data: Dict[str, np.ndarray], 
                               mode: str) -> OptimizationModel:
          """Build optimization model with appropriate complexity"""
          
          # Use NumPy arrays for efficient memory usage
          num_periods = len(forecast_data['timestamps'])
          
          # Pre-allocate variable arrays
          model = OptimizationModel(
              num_periods=num_periods,
              memory_efficient=True
          )
          
          if mode == 'simplified':
              # Simplified model with fewer variables and constraints
              model.add_basic_battery_constraints()
              model.add_simplified_thermal_constraints()
              
          elif mode == 'balanced':
              # Balanced complexity
              model.add_battery_constraints()
              model.add_thermal_constraints(detailed=False)
              model.add_ev_constraints()
              
          else:  # mode == 'full'
              # Full complexity model
              model.add_all_constraints()
              model.add_detailed_thermal_modeling()
              model.add_capacity_tariff_constraints()
          
          return model
      
      def _solve_with_monitoring(self, model: OptimizationModel, 
                               solver) -> OptimizationResult:
          """Solve optimization with real-time monitoring"""
          
          # Set solver timeout
          solver.set_time_limit(self.max_solve_time)
          
          # Monitor memory during solve
          def memory_callback():
              current_memory = psutil.Process().memory_info().rss / 1024 / 1024
              if current_memory > self.max_memory_mb:
                  self.logger.warning(f"Memory limit exceeded: {current_memory:.1f}MB")
                  return False  # Signal solver to stop
              return True
          
          # Execute solve with monitoring
          solver.set_callback(memory_callback)
          
          solve_start = time.time()
          status = solver.solve(model)
          solve_time = time.time() - solve_start
          
          if solve_time > self.max_solve_time * 0.8:
              self.logger.warning(f"Optimization approaching time limit: {solve_time:.1f}s")
          
          if status != 'optimal':
              self.logger.warning(f"Non-optimal solution: {status}")
          
          return OptimizationResult(
              status=status,
              solve_time=solve_time,
              variables=model.extract_solution(),
              performance_info=self.performance_metrics.get_current_metrics()
          )
      
      def _cleanup_caches(self):
          """Clean up memory caches when under pressure"""
          # Clear LRU caches
          self._get_cached_constraint_matrix.cache_clear()
          
          # Clear internal caches
          self._constraint_cache.clear()
          
          # Force garbage collection
          import gc
          gc.collect()
          
          self.logger.info("Memory caches cleared due to high usage")
  
  class ForecastDataCache:
      """High-performance forecast data caching with TTL"""
      
      def __init__(self, memory_cache_size: int = 128, disk_cache_ttl: int = 3600):
          self.memory_cache = {}
          self.memory_cache_size = memory_cache_size
          self.disk_cache_ttl = disk_cache_ttl
          self.access_times = {}
      
      def get_weather_forecast(self, location: str, forecast_hours: int) -> Optional[np.ndarray]:
          """Get cached weather forecast with memory and disk fallback"""
          cache_key = f"weather_{location}_{forecast_hours}"
          
          # Check memory cache first
          if cache_key in self.memory_cache:
              self.access_times[cache_key] = time.time()
              return self.memory_cache[cache_key]
          
          # Check disk cache
          disk_data = self._load_from_disk_cache(cache_key)
          if disk_data is not None:
              # Promote to memory cache
              self._add_to_memory_cache(cache_key, disk_data)
              return disk_data
          
          return None
      
      def set_weather_forecast(self, location: str, forecast_hours: int, 
                             data: np.ndarray) -> None:
          """Cache weather forecast data with efficient storage"""
          cache_key = f"weather_{location}_{forecast_hours}"
          
          # Add to memory cache
          self._add_to_memory_cache(cache_key, data)
          
          # Persist to disk cache
          self._save_to_disk_cache(cache_key, data)
      
      def _add_to_memory_cache(self, key: str, data: np.ndarray) -> None:
          """Add data to memory cache with LRU eviction"""
          if len(self.memory_cache) >= self.memory_cache_size:
              # Remove least recently used item
              lru_key = min(self.access_times.keys(), key=self.access_times.get)
              del self.memory_cache[lru_key]
              del self.access_times[lru_key]
          
          # Use memory-efficient storage
          self.memory_cache[key] = data.copy()  # Ensure data ownership
          self.access_times[key] = time.time()
      
      def _save_to_disk_cache(self, key: str, data: np.ndarray) -> None:
          """Save data to disk with compression"""
          cache_file = f"/tmp/emhass_cache_{hash(key)}.npz"
          np.savez_compressed(cache_file, data=data, timestamp=time.time())
      
      def _load_from_disk_cache(self, key: str) -> Optional[np.ndarray]:
          """Load data from disk cache with TTL check"""
          cache_file = f"/tmp/emhass_cache_{hash(key)}.npz"
          
          try:
              cache_data = np.load(cache_file)
              cache_timestamp = float(cache_data['timestamp'])
              
              # Check TTL
              if time.time() - cache_timestamp < self.disk_cache_ttl:
