                  return None
                  
          except (FileNotFoundError, KeyError):
              return None
  
  class PerformanceMetrics:
      """Track and analyze optimization performance"""
      
      def __init__(self):
          self.optimization_history = []
          self.performance_baselines = {
              'solve_time_p95': 30.0,  # 95th percentile solve time
              'memory_usage_max': 1024,  # MB
              'success_rate_min': 0.95   # Minimum success rate
          }
      
      def record_optimization(self, solve_time: float, peak_memory: float,
                            model_complexity: str, status: str) -> None:
          """Record optimization performance metrics"""
          record = {
              'timestamp': time.time(),
              'solve_time': solve_time,
              'peak_memory': peak_memory,
              'model_complexity': model_complexity,
              'status': status,
              'success': status == 'optimal'
          }
          
          self.optimization_history.append(record)
          
          # Keep only recent history (last 100 optimizations)
          if len(self.optimization_history) > 100:
              self.optimization_history = self.optimization_history[-100:]
          
          # Check against baselines
          self._check_performance_baselines(record)
      
      def _check_performance_baselines(self, record: Dict[str, Any]) -> None:
          """Check current performance against baselines"""
          if record['solve_time'] > self.performance_baselines['solve_time_p95']:
              logging.warning(f"Optimization solve time exceeded baseline: {record['solve_time']:.2f}s")
          
          if record['peak_memory'] > self.performance_baselines['memory_usage_max']:
              logging.warning(f"Peak memory usage exceeded baseline: {record['peak_memory']:.1f}MB")
      
      def get_performance_summary(self) -> Dict[str, float]:
          """Get performance summary statistics"""
          if not self.optimization_history:
              return {}
          
          solve_times = [r['solve_time'] for r in self.optimization_history]
          memory_usage = [r['peak_memory'] for r in self.optimization_history]
          success_rate = sum(r['success'] for r in self.optimization_history) / len(self.optimization_history)
          
          return {
              'avg_solve_time': np.mean(solve_times),
              'p95_solve_time': np.percentile(solve_times, 95),
              'avg_memory_usage': np.mean(memory_usage),
              'max_memory_usage': np.max(memory_usage),
              'success_rate': success_rate,
              'total_optimizations': len(self.optimization_history)
          }
